# Scope, out-of-scope entries, and rules are collected by /bounty-start.
BOUNTYPROOF_ALLOWED_PORTS=443
BOUNTYPROOF_ALLOW_HTTP=false
BOUNTYPROOF_ALLOW_PRIVATE=false
BOUNTYPROOF_VERIFY_TLS=true
BOUNTYPROOF_TIMEOUT_SECONDS=12
BOUNTYPROOF_DELAY_MS=350
BOUNTYPROOF_CONTACT=security-researcher@example.com
BOUNTYPROOF_REPORT_DIR=.bountyproof/reports
BOUNTYPROOF_MAX_URLS=100
BOUNTYPROOF_COMMAND_TIMEOUT_SECONDS=300
BOUNTYPROOF_NUCLEI_RATE_LIMIT=2
# Optional absolute paths when katana/nuclei are not on PATH.
BOUNTYPROOF_KATANA_BIN=katana
BOUNTYPROOF_NUCLEI_BIN=nuclei
# Optional: enables historical A-record candidates. Never returned in reports.
BOUNTYPROOF_SECURITYTRAILS_API_KEY=
BOUNTYPROOF_IMPORT_ROOT=.
BOUNTYPROOF_MAX_IMPORT_BYTES=20000000
